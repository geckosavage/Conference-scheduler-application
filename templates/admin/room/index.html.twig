{% extends 'base.html.twig' %}

{% block title %}Manage Rooms{% endblock %}

{% block body %}
    <div class="section-title">
        <h1>Manage Rooms</h1>
        <a class="button" href="{{ path('admin_room_new') }}">New Room</a>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Capacity</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for room in rooms %}
                    <tr>
                        <td>{{ room.name }}</td>
                        <td>{{ room.location }}</td>
                        <td>{{ room.capacity }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_room_edit', {id: room.id}) }}">Edit</a>
                                <form method="post" action="{{ path('admin_room_delete', {id: room.id}) }}" onsubmit="return confirm('Delete this room?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_room_' ~ room.id) }}">
                                    <button type="submit" class="button button-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="meta">No rooms found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
