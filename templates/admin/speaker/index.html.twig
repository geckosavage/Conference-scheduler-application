{% extends 'base.html.twig' %}

{% block title %}Manage Speakers{% endblock %}

{% block body %}
    <div class="section-title">
        <h1>Manage Speakers</h1>
        <a class="button" href="{{ path('admin_speaker_new') }}">New Speaker</a>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Expertise</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for speaker in speakers %}
                    <tr>
                        <td>{{ speaker.fullName }}</td>
                        <td>{{ speaker.expertise }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_speaker_edit', {id: speaker.id}) }}">Edit</a>
                                <form method="post" action="{{ path('admin_speaker_delete', {id: speaker.id}) }}" onsubmit="return confirm('Delete this speaker?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_speaker_' ~ speaker.id) }}">
                                    <button type="submit" class="button button-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="meta">No speakers found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
