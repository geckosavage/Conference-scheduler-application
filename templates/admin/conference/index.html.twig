{% extends 'base.html.twig' %}

{% block title %}Manage Conferences{% endblock %}

{% block body %}
    <div class="section-title">
        <h1>Manage Conferences</h1>
        <a class="button" href="{{ path('admin_conference_new') }}">New Conference</a>
    </div>

    <div class="table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Venue</th>
                    <th>Dates</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for conference in conferences %}
                    <tr>
                        <td>{{ conference.title }}</td>
                        <td>{{ conference.venue }}</td>
                        <td>{{ conference.startDate|date('d M Y') }} - {{ conference.endDate|date('d M Y') }}</td>
                        <td>{{ conference.status }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_conference_edit', {id: conference.id}) }}">Edit</a>
                                <form method="post" action="{{ path('admin_conference_delete', {id: conference.id}) }}" onsubmit="return confirm('Delete this conference?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_conference_' ~ conference.id) }}">
                                    <button type="submit" class="button button-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="meta">No conferences found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
